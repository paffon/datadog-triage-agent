TRIAGE_BACKEND=mock         # mock | datadog
TRIAGE_LLM=cli              # cli | anthropic
TRIAGE_MODEL=haiku          # agent model (haiku|sonnet|opus or full id)
TRIAGE_JUDGE_MODEL=sonnet   # judge model
TRIAGE_MAX_TURNS=6
# TRIAGE_FIXTURES_DIR=      # optional override

# --- Real Datadog MCP (opt-in) ---
DATADOG_MCP_URL=
DD_API_KEY=
DD_APPLICATION_KEY=
DD_SITE=datadoghq.com

# --- Anthropic SDK provider (opt-in alternative; needs API credits) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
